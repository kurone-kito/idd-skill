{
  "$comment": "Curated Claude Code permission baseline for this repository. See docs/permissions.md#claude-code-permission-baseline for the rationale, scope, and known flag/path matching gotchas. `gh api` is deliberately NOT allowlisted here (see the gh-api DELETE-verb trap in the doc); the DELETE-verb deny entries below are defense in depth if a future edit adds one back. Personal additions belong in .claude/settings.local.json, which layers on top of this file.",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch --list*)",
      "Bash(git branch --show-current)",
      "Bash(git branch -a*)",
      "Bash(git branch -v*)",
      "Bash(git worktree list*)",
      "Bash(git rev-parse*)",
      "Bash(git fetch origin*)",
      "Bash(git remote -v)",
      "Bash(git remote show*)",
      "Bash(git blame*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh issue comment*)",
      "Bash(gh issue edit*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr create*)",
      "Bash(gh pr comment*)",
      "Bash(gh pr edit*)",
      "Bash(gh pr review*)",
      "Bash(gh pr merge*)",
      "Bash(gh label list*)",
      "Bash(gh label create*)",
      "Bash(gh search*)",
      "Bash(gh repo view*)",
      "Bash(gh auth status)",
      "Bash(node scripts/*)",
      "Bash(node bin/*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(gh repo delete*)",
      "Bash(gh issue delete*)",
      "Bash(gh api -X DELETE*)",
      "Bash(gh api --method DELETE*)",
      "Bash(gh api --method=DELETE*)"
    ]
  }
}
