{
  // Type-check configuration for the IDD helper sources.
  //
  // Sources live in `src/**/*.mts` and are the only hand-edited JS
  // surface; the committed `scripts/*.mjs` and `bin/*.mjs` artifacts are
  // generated from them by `pnpm run build` (see `tsconfig.build.json`
  // and `docs/typescript-sources.md`).
  //
  // The `include` set covers the typed sources and the test suite; tests
  // are type-checked only (never emitted — `tsconfig.build.json` excludes
  // them) and run natively via Node's type stripping.
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],
    "strict": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.mts", "tests/**/*.mts"]
}
